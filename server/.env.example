DATABASE_URL="mysql://username:password@database-host:3306/database-name"

NODE_ENV=development
PORT=3001

AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=your_ai_api_key
AI_MODEL=your_model_name
AI_TIMEOUT_MS=60000
ENABLE_AI_MOCK=false
CORS_ORIGIN=http://hl.muytang.cn,https://hl.muytang.cn

ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=http://your-domain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=http://localhost:5173/payment/success
ALIPAY_AMOUNT=6.66

ADMIN_TOKEN=your_admin_token
